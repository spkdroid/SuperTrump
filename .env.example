# Super Trump — Production Environment Variables
#
# Copy this file to .env and fill in secure values.
# NEVER commit .env to version control.
#
# Usage with production compose:
#   docker compose -f docker-compose.prod.yml --env-file .env up -d

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── (Optional) Override DB URL if using external RDS ───────
# DATABASE_URL=postgresql://supertrump:PASSWORD@your-rds-endpoint:5432/supertrump

# ── Node / Express ─────────────────────────────────────────
NODE_ENV=production
